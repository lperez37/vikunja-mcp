# Vikunja MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Base URL of your Vikunja instance
# Example: https://vikunja.example.com or http://localhost:3456
VIKUNJA_URL=

# Required: API token for authentication
# To obtain a token:
# 1. Log into your Vikunja instance
# 2. Go to Settings > API Tokens
# 3. Create a new token with the required permissions
# 4. Copy the token value here
VIKUNJA_API_TOKEN=
