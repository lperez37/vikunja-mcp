{
  "name": "@0xk3vin/vikunja-mcp",
  "version": "1.1.0",
  "description": "MCP server for Vikunja task management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vikunja-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "mcp",
    "vikunja",
    "model-context-protocol",
    "task-management",
    "productivity",
    "ai"
  ],
  "author": "0xK3vin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xK3vin/vikunja-mcp.git"
  },
  "homepage": "https://github.com/0xK3vin/vikunja-mcp#readme",
  "bugs": {
    "url": "https://github.com/0xK3vin/vikunja-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "build": "tsc",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@modelcontextprotocol/inspector": "^0.7.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.16"
  }
}
